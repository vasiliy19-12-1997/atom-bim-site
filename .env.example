# Yandex Wiki API integration (backend only)
YANDEX_WIKI_TOKEN=your_oauth_token
YANDEX_WIKI_ORG_ID=your_org_id
YANDEX_WIKI_ROOT_SLUG=space/root-page-slug
YANDEX_WIKI_INDEX_SLUG=space/instructions-index-page

# Optional overrides
YANDEX_WIKI_API_HOST=https://api.wiki.yandex.net/v1
YANDEX_WIKI_WEB_HOST=https://wiki.yandex.ru

# Optional: comma-separated descendant slugs for building instructions tree
# YANDEX_WIKI_TREE_SLUGS=space/revit-common,space/how-to-model

# If YANDEX_WIKI_INDEX_SLUG is omitted, backend uses YANDEX_WIKI_ROOT_SLUG as the index page.
